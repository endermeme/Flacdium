FLACDIUM_SECRET=change-this-before-public-deploy
OPENCELLID_API_KEY=replace-with-your-opencellid-key
OPENCELLID_API_URL=https://opencellid.org/cell/get
FLACDIUM_TRUST_PROXY=0
FLACDIUM_STATE_DIR=/var/lib/flacdium
FLACDIUM_ADMIN_USERNAME=replace-admin-username
FLACDIUM_ADMIN_PASSWORD=replace-admin-password
FLACDIUM_MAX_REQUEST_BODY_BYTES=1073741824
FLACDIUM_MAX_UPLOAD_FILES=64
FLACDIUM_MAX_UPLOAD_FILE_BYTES=838860800
FLACDIUM_MAX_UPLOAD_TOTAL_BYTES=4294967296
FLACDIUM_MAX_ZIP_FILE_BYTES=4294967296
FLACDIUM_MAX_ZIP_MEMBERS=128
FLACDIUM_MAX_ZIP_MEMBER_BYTES=838860800
FLACDIUM_MAX_ZIP_TOTAL_UNPACKED_BYTES=6442450944
FLACDIUM_MIN_SAMPLE_RATE=44100
FLACDIUM_MIN_BIT_DEPTH=16
FLACDIUM_MIN_FINGERPRINT_DURATION_SECONDS=15
FLACDIUM_MAX_FINGERPRINT_DURATION_DELTA_SECONDS=2
FLACDIUM_MIN_FINGERPRINT_SIMILARITY=0.96
FLACDIUM_MAX_VISIBLE_UPLOADER_CREDITS=2
FLACDIUM_MIN_SPECTRAL_ANALYSIS_DURATION_SECONDS=15
FLACDIUM_SPECTRAL_LOW_ENERGY_FLOOR=6
FLACDIUM_SPECTRAL_MID_ENERGY_FLOOR=5
FLACDIUM_SPECTRAL_TOP_MID_RATIO_MAX=0.70
FLACDIUM_SPECTRAL_TOP_LOW_RATIO_MAX=0.22
FLACDIUM_SPECTRAL_ROLLOFF_MAX_HZ=17500
FLACDIUM_LOGIN_RATE_LIMIT=12
FLACDIUM_LOGIN_RATE_WINDOW_SECONDS=900
FLACDIUM_SIGNUP_RATE_LIMIT=6
FLACDIUM_SIGNUP_RATE_WINDOW_SECONDS=3600
FLACDIUM_UPLOAD_RATE_LIMIT=10
FLACDIUM_UPLOAD_RATE_WINDOW_SECONDS=3600
